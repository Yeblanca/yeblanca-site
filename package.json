    "@payloadcms/ui": "^3.83.0",
    "graphql": "^16.9.0",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next": "^16.2.4",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "payload": "^3.83.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "resend": "^6.12.0",
    "zod": "^4.3.6"
